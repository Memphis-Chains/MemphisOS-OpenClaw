{
  "name": "@memphis-chains/openclaw",
  "version": "0.1.0",
  "description": "OpenClaw — personal AI assistant gateway with multi-channel messaging and Memphis memory",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "bin": {
    "openclaw": "bin/openclaw.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.36.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
