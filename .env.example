# ── LLM provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to:
#   'ollama'    — local (default, no API key needed)
#   'anthropic' — Claude API
#   'glm'       — Zhipu AI GLM
#   'minimax'   — MiniMax
#   'memphis'   — route through Memphis (uses MEMPHIS_API_URL, handles provider selection)

LLM_PROVIDER=ollama

# Ollama — runs locally, no API key needed
OLLAMA_BASE_URL=http://localhost:11434
# Lightweight open models (pull with: ollama pull <model>):
#   qwen3.5:2b              — fast, already on most machines
#   deepseek-r1:1.5b        — tiny reasoning model, surprisingly capable
#   deepseek-r1:8b          — strong reasoning, ~5 GB RAM
#   qwen2.5:7b              — good quality / speed balance
#   deepseek-v3:latest      — DeepSeek V3 MoE (needs more RAM)
#   qwen2.5:32b             — high quality, needs ~20 GB RAM
OLLAMA_MODEL=qwen3.5:2b
# Set to 'true' to enable Qwen3 step-by-step reasoning (slower, more verbose)
OLLAMA_THINK=false

# Anthropic — set LLM_PROVIDER=anthropic to use Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek — set LLM_PROVIDER=deepseek (OpenAI-compatible, cheap & fast)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat          # or 'deepseek-reasoner' for R1 reasoning
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # default, change for self-hosted

# ── Channels ─────────────────────────────────────────────────────────────────
# Enable the ones you want — at least one required.

TELEGRAM_BOT_TOKEN=          # from @BotFather
DISCORD_BOT_TOKEN=           # from Discord Developer Portal

# ── Memphis memory layer ─────────────────────────────────────────────────────
# Optional. If not set, conversations are stateless (no recall between sessions).
MEMPHIS_API_URL=http://localhost:3000
MEMPHIS_API_TOKEN=           # matches MEMPHIS_API_TOKEN in MemphisOS .env

# ── Gateway ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Session persistence ────────────────────────────────────────────────────
# If set, chat sessions survive restarts (stored as JSON files in this dir).
# If not set, sessions are in-memory only.
OPENCLAW_DATA_DIR=
