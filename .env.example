# ── LLM provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to 'ollama' (default, local) or 'anthropic' (cloud).

LLM_PROVIDER=ollama

# Ollama — runs locally, no API key needed
OLLAMA_BASE_URL=http://localhost:11434
# Best available Qwen models (pull with: ollama pull <model>):
#   qwen3.5:2b          — fast, already on most machines
#   qwen2.5:7b          — good quality / speed balance
#   qwen2.5:32b         — high quality, needs ~20 GB RAM
#   qwen2.5:72b         — best quality, needs ~48 GB RAM
OLLAMA_MODEL=qwen3.5:2b
# Set to 'true' to enable Qwen3 step-by-step reasoning (slower, more verbose)
OLLAMA_THINK=false

# Anthropic — set LLM_PROVIDER=anthropic to use Claude instead
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Channels ─────────────────────────────────────────────────────────────────
# Enable the ones you want — at least one required.

TELEGRAM_BOT_TOKEN=          # from @BotFather
DISCORD_BOT_TOKEN=           # from Discord Developer Portal

# ── Memphis memory layer ─────────────────────────────────────────────────────
# Optional. If not set, conversations are stateless (no recall between sessions).
MEMPHIS_API_URL=http://localhost:3000
MEMPHIS_API_TOKEN=           # matches MEMPHIS_API_TOKEN in MemphisOS .env

# ── Gateway ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
